# Logging
LOG_LEVEL=INFO
APPNAME="Truth Social Monitor"
ENV=PROD
REPEAT_DELAY=300

# Discord
DISCORD_NOTIFY=true
DISCORD_USERNAME="Truth Social Bot"
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# MongoDB — when using docker compose, MONGO_DBSTRING is automatically set to the local container.
# Only set this if running outside of docker compose.
# MONGO_DBSTRING=mongodb://localhost:27017/
MONGO_DB=truthsocial
MONGO_COLLECTION=posts

# Truth Social
TRUTH_USERNAME=username_to_monitor
TRUTH_INSTANCE=truthsocial.com
POST_TYPE=post

# Request Settings
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# FlareSolverr — when using docker compose, FLARESOLVERR_ADDRESS is automatically set to the container name.
# Only set this if running outside of docker compose.
# FLARESOLVERR_ADDRESS=localhost
FLARESOLVERR_PORT=8191
